DATABASE_URL=postgresql://username:password@localhost:5432/qsafe
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random
PORT=3000
HSM_MOCK=true
HSM_PORT=COM3
CORS_ORIGIN=http://localhost:3000
DB_MAX_CONNECTIONS=10

# Only used by docker-compose.yml (substituted into the postgres container's
# password and the backend's DATABASE_URL for the docker-compose deployment;
# not read directly by the Rust binary, which only uses DATABASE_URL above).
POSTGRES_PASSWORD=change-this-to-a-real-random-password
